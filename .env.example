# Public demo mode uses bundled sample reports and never calls external APIs.
DEMO_MODE=true

# Optional local-only key for live evaluation. Do not commit real keys.
OPENAI_API_KEY=

# Default evaluation config used by the CLI/dashboard.
DEFAULT_CONFIG_PATH=evals/config.yaml

# Directory for generated reports. Hugging Face free storage is ephemeral.
REPORTS_DIR=reports

# Keep false in public deployments to prevent spending API quota.
ALLOW_LIVE_RUNS=false

# Use "demo" for deterministic local/HF demo artifacts.
BENCHMARK_MODE=demo

# Optional live-eval controls.
OPENAI_MODEL=gpt-4o-mini
LIVE_MAX_CASES=3
